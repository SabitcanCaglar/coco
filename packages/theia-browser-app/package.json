{
  "name": "@coco/theia-browser-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "bundle": "theia build --mode development",
    "start": "theia start --hostname 127.0.0.1 --port 3001",
    "watch": "theia build --watch --mode development"
  },
  "dependencies": {
    "@coco/theia": "workspace:*",
    "@theia/application-package": "latest",
    "@theia/core": "latest",
    "@theia/editor": "latest",
    "@theia/filesystem": "latest",
    "@theia/messages": "latest",
    "@theia/monaco": "latest",
    "@theia/monaco-editor-core": "latest",
    "@theia/navigator": "latest",
    "@theia/preferences": "latest",
    "@theia/process": "latest",
    "@theia/terminal": "latest",
    "@theia/workspace": "latest",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@theia/cli": "latest",
    "css-loader": "^7.1.2",
    "source-map-loader": "^5.0.0",
    "style-loader": "^4.0.0"
  },
  "theia": {
    "frontend": {
      "config": {
        "applicationName": "Coco IDE"
      }
    },
    "target": "browser"
  }
}
